# Personal data - keep root folder structure only
knowledge/**/*
!knowledge/**/
!knowledge/**/.gitkeep
!knowledge/**/README.md

# Tasks (personal work items)
tasks/*
!tasks/.gitkeep
!tasks/README.md

# Meetings (personal transcripts)
meetings/*
!meetings/.gitkeep
!meetings/README.md

# Projects (committed work, personal)
projects/**/*
!projects/**/
!projects/**/.gitkeep
!projects/**/AGENTS.md
!projects/**/CLAUDE.md

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.obsidian/
.cursor/
.idea/
*.swp
*.swo

# Claude Code
.claude/*
!.claude/skills/
!.claude/settings.json

# Environment
.env
.env.local
.venv

# Logs
*.log
logs/

# Build artifacts (if using MCP servers)
*.pyc
__pycache__/
.pytest_cache/

# Integration caches (workspace-specific data)
tools/integrations/slack/mappings.json


# Temp drop zone (files in transit, scratch work)
_temp/*
!_temp/.gitkeep

# Agent system files — always tracked even inside gitignored directories
!**/AGENTS.md
!**/CLAUDE.md

# Personal backlog (private daily inbox)
BACKLOG.md

# Personal goals (private quarterly objectives)
GOALS.md

# Personal voice guide (writing style preferences)
VOICE-GUIDE.md

# Evals (test results and backups)
evals/results/
*.backup

# Project todos
TODO.md

.mcp.json